<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.tilas.mapper.DeptMapper">

    <!-- Dept 实体字段映射 -->
    <resultMap id="DeptResultMap" type="com.example.tilas.pojo.Dept">
        <id     column="id"           property="id"/>
        <result column="name"         property="name"/>
        <result column="create_time"  property="createTime"/>
        <result column="update_time"  property="updateTime"/>
    </resultMap>

    <!-- 查询所有部门 -->
    <select id="findAll" resultMap="DeptResultMap">
        select id, name, create_time, update_time
        from dept
        order by update_time desc
    </select>

    <!-- 按 id 删除 -->
    <delete id="deleteById" parameterType="int">
        delete from dept where id = #{id}
    </delete>

    <!-- 新增部门 -->
    <insert id="insert" parameterType="com.example.tilas.pojo.Dept">
        insert into dept(name, create_time, update_time)
        values (#{name}, #{createTime}, #{updateTime})
    </insert>

    <!-- 按 id 查询 -->
    <select id="getById" parameterType="int" resultMap="DeptResultMap">
        select id, name, create_time, update_time
        from dept
        where id = #{id}
    </select>

    <!-- 修改部门 -->
    <update id="update" parameterType="com.example.tilas.pojo.Dept">
        update dept
        set name = #{name},
            update_time = #{updateTime}
        where id = #{id}
    </update>

</mapper>