<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.tilas.mapper.EmpExprMapper">
    <insert id="insertBatch" parameterType="com.example.tilas.pojo.EmpExpr">
        insert into emp_expr (emp_id, begin, end, company, job) VALUES
        <foreach collection="exprList" separator="," item="expr">
            (#{expr.empId}, #{expr.begin}, #{expr.end}, #{expr.company}, #{expr.job})
        </foreach>
    </insert>
    <!--    批量删除员工工作经历信息-->
    <delete id="deleteByEmpIds">
        delete from emp_expr where emp_id in
        <foreach collection="empIds" item="empId" open="(" close=")" separator=",">
            #{empId}
        </foreach>
    </delete>


</mapper>
